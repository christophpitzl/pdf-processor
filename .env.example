# ==============================================================================
# PDF Processor — Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env
# All values shown here are the built-in defaults.
# ==============================================================================

# ── NFS ─────────────────────────────────────────────────────────────────────────
# The NFS share must be mounted on the Docker host at /mnt/nfs (or a custom path).
# The container bind-mounts this directory so it can process PDFs directly.
#
# Example /etc/fstab entry on the host:
#   <nfs-server>:/export/path  /mnt/nfs  nfs  hard,intr,noatime  0  0
#
# NFS_WATCH_DIR=/mnt/nfs/incoming
# NFS_OUTPUT_DIR=/mnt/nfs/processed
#
# Optional — used only for diagnostics display:
# NFS_SERVER=<nfs-server-ip>:/export/path
# NFS_EXPORT_PATH=/export/path
# NFS_MOUNT_OPTIONS=hard,intr,noatime
#
# Host path to bind-mount into the container (must point to the NFS mount):
# NFS_HOST_MOUNT=/mnt/nfs

# ── Ollama (local AI) ───────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://ollama.pitzl.net:11434
# OLLAMA_MODEL=granite4.1:3b  # Recommended: returns clean JSON without markdown

# ── Wake-on-LAN (wake Ollama server automatically) ──────────────────────────────
# OLLAMA_WOL_ENABLED=false
# OLLAMA_MAC_ADDRESS=
# OLLAMA_BROADCAST_HOST=[IP_ADDRESS]
# OLLAMA_WOL_PORT=9
# OLLAMA_WOL_RETRIES=10
# OLLAMA_WOL_RETRY_DELAY=5.0

# ── PDF Processing ──────────────────────────────────────────────────────────────
# SCAN_DATE_FORMAT=%Y-%m-%d
# MIN_CONFIDENCE=0.6
# FILENAME_PATTERN={date}_{type}_{summary}.pdf
# CHECK_INTERVAL=60

# ── Web Interface ───────────────────────────────────────────────────────────────
# WEB_HOST=[IP_ADDRESS]
# WEB_PORT=8080

# ── Paths ───────────────────────────────────────────────────────────────────────
# DATA_DIR=./data
# LOGS_DIR=./logs

# ── Logging ─────────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
