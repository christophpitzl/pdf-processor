# ==============================================================================
# PDF Processor — Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env
# All values shown here are the built-in defaults.
# ==============================================================================

# ── NFS ─────────────────────────────────────────────────────────────────────────
# The container will automatically mount the NFS share at startup.
# You only need to specify the server and which folder to mount.
#
# NFS server IP or hostname
# NFS_SERVER=192.168.1.100
#
# Export path on the NFS server (mount source)
# NFS_EXPORT_PATH=/volume1/webdav/pdf-processor
#
# Subdirectory for incoming PDFs (relative to the mount point)
# NFS_INCOMING_SUBDIR=/incoming
#
# Subdirectory for processed PDFs (relative to the mount point)
# NFS_PROCESSED_SUBDIR=/processed
#
# NFS mount options (optional, defaults shown)
# NFS_MOUNT_OPTIONS=hard,intr,noatime

# ── Ollama (local AI) ───────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://ollama.pitzl.net:11434
# OLLAMA_MODEL=granite4.1:3b  # Recommended: returns clean JSON without markdown

# ── Wake-on-LAN (wake Ollama server automatically) ──────────────────────────────
# OLLAMA_WOL_ENABLED=false
# OLLAMA_MAC_ADDRESS=
# OLLAMA_BROADCAST_HOST=[IP_ADDRESS]
# OLLAMA_WOL_PORT=9
# OLLAMA_WOL_RETRIES=10
# OLLAMA_WOL_RETRY_DELAY=5.0

# ── PDF Processing ──────────────────────────────────────────────────────────────
# SCAN_DATE_FORMAT=%Y-%m-%d
# MIN_CONFIDENCE=0.6
# FILENAME_PATTERN={date}_{type}_{summary}.pdf
# CHECK_INTERVAL=60

# ── Web Interface ───────────────────────────────────────────────────────────────
# WEB_HOST=[IP_ADDRESS]
# WEB_PORT=8080

# ── Logging ─────────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
