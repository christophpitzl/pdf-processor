# ==============================================================================
# PDF Processor — Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env
# All values shown here are the built-in defaults.
# ==============================================================================

# ── WebDAV ──────────────────────────────────────────────────────────────────────
# WEBDAV_URL=http://nas.local/webdav
# WEBDAV_USERNAME=
# WEBDAV_PASSWORD=
# WEBDAV_WATCH_FOLDER=/incoming
# WEBDAV_OUTPUT_FOLDER=/processed

# ── Ollama (local AI) ───────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:0.8b

# ── Wake-on-LAN (wake Ollama server automatically) ──────────────────────────────
# OLLAMA_WOL_ENABLED=false
# OLLAMA_MAC_ADDRESS=
# OLLAMA_BROADCAST_HOST=[IP_ADDRESS]
# OLLAMA_WOL_PORT=9
# OLLAMA_WOL_RETRIES=10
# OLLAMA_WOL_RETRY_DELAY=5.0

# ── PDF Processing ──────────────────────────────────────────────────────────────
# SCAN_DATE_FORMAT=%Y-%m-%d
# MIN_CONFIDENCE=0.6
# FILENAME_PATTERN={date}_{type}_{summary}.pdf
# CHECK_INTERVAL=60

# ── Web Interface ───────────────────────────────────────────────────────────────
# WEB_HOST=[IP_ADDRESS]
# WEB_PORT=8080

# ── Paths ───────────────────────────────────────────────────────────────────────
# DATA_DIR=./data
# LOGS_DIR=./logs

# ── Logging ─────────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
