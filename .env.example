# ==============================================================================
# PDF Processor — Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env
# All values shown here are the built-in defaults.
# ==============================================================================

# ── Directories (host-mounted volumes) ──────────────────────────────────────────
# These point to the container-side paths. Map your host folders to these paths
# using docker-compose.yml volume mounts (or docker -v flags).
#
# INCOMING_DIR=/incoming
# PROCESSED_DIR=/processed

# ── Ollama (local AI) ───────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://ollama.pitzl.net:11434
# OLLAMA_MODEL=granite4.1:3b  # Recommended: returns clean JSON without markdown

# ── PDF Processing ──────────────────────────────────────────────────────────────
# SCAN_DATE_FORMAT=%Y-%m-%d
# MIN_CONFIDENCE=0.6
# FILENAME_PATTERN={date}_{type}_{summary}.pdf
# CHECK_INTERVAL=60
# LANGUAGE=de  # 'de' for German, 'en' for English

# ── Web Interface ───────────────────────────────────────────────────────────────
# WEB_HOST=[IP_ADDRESS]
# WEB_PORT=8080

# ── Logging ─────────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
